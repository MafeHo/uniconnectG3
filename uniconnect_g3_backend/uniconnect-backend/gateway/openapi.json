{
  "openapi": "3.0.0",
  "info": {
    "title": "UniConnect API Gateway",
    "description": "Especificación centralizada de la API del ecosistema de microservicios UniConnect G3. Ruteado mediante API Gateway.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "API Gateway Local"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Iniciar Sesión",
        "description": "Autentica a un usuario y retorna un token JWT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "user@unicaldas.edu.co" },
                  "password": { "type": "string", "example": "password123" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autenticación exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "user": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/profile": {
      "get": {
        "summary": "Obtener Perfil Académico",
        "description": "Recupera el perfil del estudiante autenticado.",
        "responses": {
          "200": { "description": "Perfil recuperado exitosamente" }
        }
      }
    },
    "/api/groups": {
      "get": {
        "summary": "Listar Grupos Sociales",
        "description": "Retorna los grupos académicos o deportivos disponibles.",
        "responses": {
          "200": { "description": "Listado de grupos exitoso" }
        }
      }
    },
    "/api/chats": {
      "get": {
        "summary": "Listar Chats Privados",
        "description": "Retorna los canales de mensajería del usuario.",
        "responses": {
          "200": { "description": "Listado de chats exitoso" }
        }
      }
    },
    "/api/notifications": {
      "get": {
        "summary": "Listar Notificaciones",
        "description": "Retorna las notificaciones in-app del usuario.",
        "responses": {
          "200": { "description": "Listado de notificaciones exitoso" }
        }
      }
    }
  }
}
